# Copy to .env (NOT committed) and fill in real values. Never commit .env.

# Alpaca PAPER credentials — get from https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=PK_paper_key_here
ALPACA_SECRET_KEY=secret_here

# DO NOT change to a live endpoint. The code refuses anything but the paper host.
# (The alpaca-py SDK appends /v2 on its own.)
ALPACA_ENDPOINT=https://paper-api.alpaca.markets

# This project is paper-only. Even set to true, the code stays paper-only.
LIVE_TRADING_AUTHORIZED=false

# Risk-free rate used by metrics.py for the Sharpe ratio (decimal). Default 0.045.
RISK_FREE_RATE=0.045

# --- Cloud routines only ---
# Set these as environment variables ON each Claude Code cloud routine (not here).
# They let isolated cloud runs remember state between runs by pushing to GitHub.
# AGENTIC_SYNC=1
# GITHUB_TOKEN=github_pat_with_contents_write
